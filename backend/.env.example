JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Local dev (SQLite)
# DATABASE_URL=sqlite:///./eduverse.db

# Supabase PostgreSQL (Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# fal.ai (AI Orchestrator + FalService)
FAL_KEY=your-fal-api-key
FAL_MOCK_MODE=false
FAL_MEME_MODEL=fal-ai/flux/schnell
FAL_IMAGE_MODEL=fal-ai/flux/schnell
FAL_VIDEO_MODEL=fal-ai/minimax-video/image-to-video
FAL_VISION_MODEL=fal-ai/florence-2-large/caption
FAL_TTS_MODEL=fal-ai/kokoro/american-english
FAL_LLM_ENDPOINT=fal-ai/any-llm
FAL_LLM_MODEL=google/gemini-2.0-flash-001
FAL_LLM_MAX_TOKENS=1024
